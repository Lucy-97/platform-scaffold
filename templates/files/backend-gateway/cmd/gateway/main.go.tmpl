// {{.Brand}} Gateway 入口。
//
// 设计要点：
//   - 全局中间件链：Recovery → CORS → RequestID → Metrics → JWT → RateLimit
//   - JWT 在限流前运行，保证 RateLimit 能拿到 userUUID
//   - 所有业务路由通过 proxy 转发到下游 API/AI Engine
//   - 下游通过 X-Internal-Secret 校验本网关身份
package main

import (
	"context"
	"fmt"
	"log/slog"
	"net/http"
	"os"
	"os/signal"
	"syscall"
	"time"

	"github.com/gin-gonic/gin"
	"github.com/prometheus/client_golang/prometheus/promhttp"
	"github.com/redis/go-redis/v9"

	"{{.GoModulePath}}/backend-gateway/internal/config"
	"{{.GoModulePath}}/backend-gateway/internal/router"
	pmw "{{.GoModulePath}}/backend-gateway/internal/middleware"
	gwjwt "{{.GoModulePath}}/backend-gateway/pkg/jwt"
)

func main() {
	cfg := config.Load()

	// ─── Redis 连接（限流计数）───
	rdb := redis.NewClient(&redis.Options{
		Addr:     fmt.Sprintf("%s:%s", cfg.Redis.Host, cfg.Redis.Port),
		Password: cfg.Redis.Password,
		DB:       cfg.Redis.DB,
	})
	if err := rdb.Ping(context.Background()).Err(); err != nil {
		slog.Warn("Redis connection failed, rate limiting disabled", "error", err)
		rdb = nil
	} else {
		slog.Info("Redis connected")
	}

	jwtManager := gwjwt.NewManager(cfg.JWT.Secret, cfg.JWT.AccessTokenExpSec, cfg.JWT.RefreshTokenExpDays)

	r := gin.New()
	r.Use(gin.Recovery())
	r.Use(pmw.CORS(cfg.CORS.AllowedOrigins))
	r.Use(pmw.RequestID())
	r.Use(pmw.PrometheusMetrics())
	r.Use(pmw.JWT(jwtManager, pmw.JWTOptions{
		PublicPathPrefixes:     cfg.JWT.PublicPaths,
		RefreshTokenCookieName: "refreshToken_",
	}))
	if rdb != nil {
		r.Use(pmw.RateLimit(pmw.NewRedisRateLimiter(rdb, 300, time.Minute)))
	}

	router.SetupRoutes(r, cfg)

	r.GET("/health", func(c *gin.Context) {
		c.JSON(200, gin.H{"status": "ok", "service": "{{.ProjectName}}-gateway"})
	})
	r.GET("/metrics", gin.WrapH(promhttp.Handler()))

	srv := &http.Server{Addr: ":" + cfg.Server.Port, Handler: r}
	go func() {
		slog.Info("Gateway starting", "port", cfg.Server.Port)
		if err := srv.ListenAndServe(); err != nil && err != http.ErrServerClosed {
			slog.Error("Failed to start gateway", "error", err)
			os.Exit(1)
		}
	}()

	ctx, stop := signal.NotifyContext(context.Background(), syscall.SIGINT, syscall.SIGTERM)
	defer stop()
	<-ctx.Done()

	slog.Info("Shutting down...")
	shutdownCtx, cancel := context.WithTimeout(context.Background(), 30*time.Second)
	defer cancel()
	if err := srv.Shutdown(shutdownCtx); err != nil {
		slog.Error("Forced shutdown", "error", err)
	}
	if rdb != nil {
		_ = rdb.Close()
	}
	slog.Info("Server stopped")
}
