"""配置：通过 pydantic-settings 从环境变量读取。"""
from functools import lru_cache
from typing import List

from pydantic import Field
from pydantic_settings import BaseSettings, SettingsConfigDict


class Settings(BaseSettings):
    """AI Engine 运行时配置。"""

    model_config = SettingsConfigDict(env_file=".env", extra="ignore")

    # ─── Server ───
    port: int = Field(default={{.Ports.AIEngine}}, alias="AI_ENGINE_PORT")
    env: str = Field(default="dev", alias="APP_ENV")

    # ─── Internal Auth ───
    internal_secret: str = Field(default="", alias="INTERNAL_API_SECRET")

    # ─── Upstream API（Python 端只读，写操作需委托给 Go API）───
    api_base_url: str = Field(default="http://localhost:{{.Ports.API}}", alias="API_BASE_URL")

    # ─── CORS（一般直接由 gateway 处理，这里默认空）───
    cors_origins: List[str] = Field(default_factory=list, alias="CORS_ORIGINS")


@lru_cache
def get_settings() -> Settings:
    return Settings()
