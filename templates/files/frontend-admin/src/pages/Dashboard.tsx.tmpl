import { useEffect, useState } from "react";
import { api } from "../api";

interface User {
  uuid: string;
  email: string;
  nickname?: string;
  memberLevel: string;
}

export default function DashboardPage() {
  const [users, setUsers] = useState<User[]>([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    (async () => {
      try {
        const json = await api<{ data?: User[] }>("/admin/users");
        if (json.code === "200") setUsers(json.data?.data ?? []);
      } finally {
        setLoading(false);
      }
    })();
  }, []);

  return (
    <div style={pageStyle}>
      <h1>{{.Brand}} Admin Dashboard</h1>
      <p>占位页：用户列表（接入 /admin/users 后替换）</p>
      {loading ? (
        <p>Loading...</p>
      ) : (
        <table>
          <thead>
            <tr>
              <th>UUID</th>
              <th>Email</th>
              <th>Nickname</th>
              <th>Level</th>
            </tr>
          </thead>
          <tbody>
            {users.map((u) => (
              <tr key={u.uuid}>
                <td>{u.uuid}</td>
                <td>{u.email}</td>
                <td>{u.nickname ?? "-"}</td>
                <td>{u.memberLevel}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  );
}

const pageStyle: React.CSSProperties = { padding: 32, fontFamily: "system-ui" };
