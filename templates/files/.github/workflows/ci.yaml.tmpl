name: {{.ProjectName}} CI

on:
  push:
    branches: [ "main" ]
  pull_request:
    branches: [ "main" ]

# 注意：本仓库为多模块（每个服务独立 go.mod / package.json），
# 各 job 用 working-directory 进入对应服务，不在仓库根跑 go ./...。

jobs:
  backend:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: '1.22'
      - name: gateway — vet & build & test
        working-directory: backend-gateway
        run: |
          go mod tidy
          go vet ./...
          go build ./...
          go test ./...
      - name: api — vet & build & test
        working-directory: backend-api
        run: |
          go mod tidy
          go vet ./...
          go build ./...
          go test ./...
{{- if .Features.Web }}

  frontend-web:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '20'
      - name: web — typecheck & build
        working-directory: frontend-web
        run: |
          npm install
          npx tsc --noEmit
          npm run build --if-present
{{- end }}
{{- if .Features.Admin }}

  frontend-admin:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '20'
      - name: admin — typecheck & build
        working-directory: frontend-admin
        run: |
          npm install
          npx tsc --noEmit
          npm run build --if-present
{{- end }}
