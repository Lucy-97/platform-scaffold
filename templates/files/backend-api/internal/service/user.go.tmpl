// Package service 业务逻辑层（原子服务）。
//
// 定位：Handler / Engine → **Service** → Repository
//
// Service 负责单一职责的原子操作（查用户、签 JWT、发邮件）。
// 复杂的多步编排请放到 engine 层。
package service

import (
	"context"
	"fmt"

	"github.com/google/uuid"
	"github.com/redis/go-redis/v9"

	"{{.GoModulePath}}/backend-api/internal/model"
	"{{.GoModulePath}}/backend-api/internal/repository"
)

// UserService 用户原子服务。
type UserService interface {
	GetByUUID(ctx context.Context, uuid string) (*model.User, error)
	CreateUser(ctx context.Context, email, nickname string) (*model.User, error)
}

type userService struct {
	repo repository.UserRepository
	rdb  *redis.Client
}

// NewUserService 创建用户服务。rdb 可为 nil（缓存优雅降级）。
func NewUserService(repo repository.UserRepository, rdb *redis.Client) UserService {
	return &userService{repo: repo, rdb: rdb}
}

// GetByUUID 通过业务 UUID 拉取用户。
func (s *userService) GetByUUID(ctx context.Context, uuid string) (*model.User, error) {
	if uuid == "" {
		return nil, fmt.Errorf("uuid required")
	}
	return s.repo.FindByUUID(ctx, uuid)
}

// CreateUser 创建用户（原子操作，不含编排逻辑）。
func (s *userService) CreateUser(ctx context.Context, email, nickname string) (*model.User, error) {
	u := &model.User{
		UUID:     uuid.New().String(),
		Email:    email,
		Nickname: nickname,
	}
	if err := s.repo.Create(ctx, u); err != nil {
		return nil, err
	}
	return u, nil
}
