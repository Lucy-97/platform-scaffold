// Package dynconfig 在应用启动时从 system_config 表加载并解密配置，
// 通过 setter 回调写入业务 Config。
//
// 设计要点：
//   - 仅启动时加载一次（非热更新）
//   - 加密值（encrypted=1）使用 master key 通过 AES-256-GCM 解密
//   - 优雅降级：缺失或解密失败不阻止启动，仅日志警告
//   - 业务方提供 setters map[key]func(val string)，本包负责拉数据 + 解密 + 调用
//
// 用法：
//
//	setters := map[string]dynconfig.Setter{
//	    "GOOGLE_CLIENT_SECRET": func(v string) { cfg.GoogleClientSecret = v },
//	    "PADDLE_API_KEY":       func(v string) { cfg.PaddleAPIKey = v },
//	}
//	dynconfig.Load(db, masterKey, setters)
package dynconfig

import (
	"log"

	"gorm.io/gorm"

	"{{.GoModulePath}}/backend-api/internal/crypto"
)

// Setter 把解密后的字符串值写入业务 Config 对应字段。
type Setter func(val string)

// Options 控制加载行为。零值即默认。
type Options struct {
	// TableName 默认 "system_config"。
	TableName string
	// KeyColumn 默认 "config_key"。
	KeyColumn string
	// ValueColumn 默认 "config_val"。
	ValueColumn string
	// EncryptedColumn 默认 "encrypted"。
	EncryptedColumn string
	// LogPrefix 日志前缀，默认 "[DynConfig]"。
	LogPrefix string
}

func (o *Options) withDefaults() {
	if o.TableName == "" {
		o.TableName = "system_config"
	}
	if o.KeyColumn == "" {
		o.KeyColumn = "config_key"
	}
	if o.ValueColumn == "" {
		o.ValueColumn = "config_val"
	}
	if o.EncryptedColumn == "" {
		o.EncryptedColumn = "encrypted"
	}
	if o.LogPrefix == "" {
		o.LogPrefix = "[DynConfig]"
	}
}

// Load 从动态配置表加载键值，逐个调用 setter。
// 优雅降级：所有失败都只记录日志，不阻止启动。
func Load(db *gorm.DB, masterKey string, setters map[string]Setter) {
	LoadWithOptions(db, masterKey, setters, Options{})
}

// LoadWithOptions 自定义表名/列名版本。
func LoadWithOptions(db *gorm.DB, masterKey string, setters map[string]Setter, opts Options) {
	opts.withDefaults()

	if len(setters) == 0 {
		return
	}

	if masterKey == "" {
		log.Printf("%s ⚠️ master key 未设置，跳过加密凭据加载（服务仍可启动）", opts.LogPrefix)
	}

	loaded, skipped := 0, 0
	for key, setter := range setters {
		val, encrypted, err := findValue(db, opts, key)
		if err != nil {
			log.Printf("%s ⚠️ DB 查询失败 key=%s: %v", opts.LogPrefix, key, err)
			skipped++
			continue
		}
		if val == "" {
			skipped++
			continue
		}
		if encrypted {
			if masterKey == "" {
				skipped++
				continue
			}
			decrypted, derr := crypto.Decrypt(val, masterKey)
			if derr != nil {
				log.Printf("%s ⚠️ 解密失败 key=%s: %v", opts.LogPrefix, key, derr)
				skipped++
				continue
			}
			val = decrypted
		}
		setter(val)
		loaded++
		log.Printf("%s ✅ loaded %s", opts.LogPrefix, key)
	}

	if skipped > 0 {
		log.Printf("%s ⚠️ 跳过 %d 个未就绪凭据（可后续通过 Admin 写入）", opts.LogPrefix, skipped)
	}
	log.Printf("%s 共加载 %d 个动态配置项", opts.LogPrefix, loaded)
}

// findValue 拉取单条动态配置。
func findValue(db *gorm.DB, opts Options, key string) (val string, encrypted bool, err error) {
	row := struct {
		Val       string `gorm:"column:val"`
		Encrypted int    `gorm:"column:encrypted"`
	}{}
	q := db.Table(opts.TableName).
		Select(opts.ValueColumn+" AS val, "+opts.EncryptedColumn+" AS encrypted").
		Where(opts.KeyColumn+" = ?", key).
		Take(&row)
	if q.Error != nil {
		if q.Error == gorm.ErrRecordNotFound {
			return "", false, nil
		}
		return "", false, q.Error
	}
	return row.Val, row.Encrypted == 1, nil
}
