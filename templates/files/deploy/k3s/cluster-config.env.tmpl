# {{.Brand}} K3s 集群配置
#
# 用于部署到自建 K3s 集群。复制为 cluster-config.env 并填好实际值后，
# 运行 ./install.sh 一键将本机 kubeconfig 切到目标集群。

# K3s 节点 SSH 地址
K3S_NODE_HOST=root@your-k3s-host
K3S_NODE_SSH_PORT=22

# 镜像仓库（image push 目标）
REGISTRY=registry.{{.Domain}}
REGISTRY_USER=
REGISTRY_PASSWORD=

# 命名空间
NAMESPACE={{.ProjectName}}

# 应用域名
APP_DOMAIN={{.Domain}}
