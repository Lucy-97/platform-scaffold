# {{.Brand}} K3s Services + Ingress
#
# 由 install.sh deploy 调用，envsubst 注入 ${APP_DOMAIN}。
# Ingress 使用 K3s 默认的 traefik，HTTPS 由 cert-manager 或 traefik 自动签发。
---
apiVersion: v1
kind: Service
metadata: { name: gateway }
spec:
  selector: { app: gateway }
  ports: [{ port: {{.Ports.Gateway}}, targetPort: {{.Ports.Gateway}} }]
---
apiVersion: v1
kind: Service
metadata: { name: api }
spec:
  selector: { app: api }
  ports: [{ port: {{.Ports.API}}, targetPort: {{.Ports.API}} }]
{{- if .Features.AIEngine }}
---
apiVersion: v1
kind: Service
metadata: { name: ai-engine }
spec:
  selector: { app: ai-engine }
  ports: [{ port: {{.Ports.AIEngine}}, targetPort: {{.Ports.AIEngine}} }]
{{- end }}
{{- if .Features.Web }}
---
apiVersion: v1
kind: Service
metadata: { name: web }
spec:
  selector: { app: web }
  ports: [{ port: {{.Ports.Web}}, targetPort: {{.Ports.Web}} }]
{{- end }}
{{- if .Features.Admin }}
---
apiVersion: v1
kind: Service
metadata: { name: admin }
spec:
  selector: { app: admin }
  ports: [{ port: 80, targetPort: 80 }]
{{- end }}
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{.ProjectName}}-ingress
  annotations:
    traefik.ingress.kubernetes.io/router.tls: "true"
    traefik.ingress.kubernetes.io/router.entrypoints: "websecure"
spec:
  rules:
    - host: ${APP_DOMAIN}
      http:
        paths:
          - path: /api
            pathType: Prefix
            backend: { service: { name: gateway, port: { number: {{.Ports.Gateway}} } } }
          {{- if .Features.Web }}
          - path: /
            pathType: Prefix
            backend: { service: { name: web, port: { number: {{.Ports.Web}} } } }
          {{- end }}
    {{- if .Features.Admin }}
    - host: admin.${APP_DOMAIN}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend: { service: { name: admin, port: { number: 80 } } }
    {{- end }}
  tls:
    - hosts:
        - ${APP_DOMAIN}
        {{- if .Features.Admin }}
        - admin.${APP_DOMAIN}
        {{- end }}
      secretName: {{.ProjectName}}-tls
