#!/bin/bash
# ═══════════════════════════════════════════════════
# db-apply.sh — 本地数据库迁移工具
#
# 用法:
#   bash deploy/local/db-apply.sh <SQL文件路径>
#
# 示例:
#   bash deploy/local/db-apply.sh database/init.sql
#   bash deploy/local/db-apply.sh database/migrations/20260610-add-orders-table.sql
#
# 执行策略:
#   1. 优先通过运行中的 Docker MySQL 容器执行
#   2. 若未运行 Docker，降级为本地 mysql 客户端直连
# ═══════════════════════════════════════════════════

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
ENV_FILE="${PROJECT_ROOT}/deploy/local/.env"

# 默认连接参数
DB_USER="root"
DB_PASS=""
DB_HOST="127.0.0.1"
DB_PORT="{{.Ports.MySQL}}"
DB_NAME="{{.ProjectName}}"

# 从 .env 读取覆盖
if [ -f "${ENV_FILE}" ]; then
    _get() { grep -E "^${1}=" "${ENV_FILE}" | head -n1 | cut -d'=' -f2- | tr -d '"' | tr -d "'" || true; }
    [ -n "$(_get MYSQL_USER)" ]     && DB_USER="$(_get MYSQL_USER)"
    [ -n "$(_get MYSQL_PASSWORD)" ] && DB_PASS="$(_get MYSQL_PASSWORD)"
    [ -n "$(_get MYSQL_HOST)" ]     && DB_HOST="$(_get MYSQL_HOST)"
    [ -n "$(_get MYSQL_PORT)" ]     && DB_PORT="$(_get MYSQL_PORT)"
    [ -n "$(_get MYSQL_DB)" ]       && DB_NAME="$(_get MYSQL_DB)"
fi

# 参数校验
SQL_FILE="$1"
if [ -z "${SQL_FILE}" ]; then
    echo "❌ 用法: $0 <SQL文件路径>"
    echo "示例: $0 database/init.sql"
    exit 1
fi

if [ ! -f "${SQL_FILE}" ]; then
    if [ -f "${PROJECT_ROOT}/${SQL_FILE}" ]; then
        SQL_FILE="${PROJECT_ROOT}/${SQL_FILE}"
    else
        echo "❌ SQL 文件不存在: ${SQL_FILE}"
        exit 1
    fi
fi

SQL_BASENAME=$(basename "${SQL_FILE}")
SQL_LINES=$(wc -l < "${SQL_FILE}" | tr -d ' ')

echo "═══════════════════════════════════════════"
echo " 数据库迁移"
echo "═══════════════════════════════════════════"
echo ""
echo "▶ SQL 文件: ${SQL_BASENAME} (${SQL_LINES} 行)"
echo "▶ 目标库:   ${DB_NAME}"
echo ""

# SQL 预览
echo "┌─────────────────────────────────────────┐"
echo "│  SQL 内容预览                            │"
echo "└─────────────────────────────────────────┘"
grep -v '^--' "${SQL_FILE}" | grep -v '^$' | head -15
TOTAL_STMTS=$(grep -v '^--' "${SQL_FILE}" | grep -v '^$' | grep -c ';' || true)
echo ""
echo "  共 ${TOTAL_STMTS} 条 SQL 语句"
echo ""

# 确认
echo -n "⚠️ 确认执行迁移到 [${DB_NAME}]？(y/N): "
read -r CONFIRM
if [ "${CONFIRM}" != "y" ] && [ "${CONFIRM}" != "Y" ]; then
    echo "已取消。"
    exit 0
fi

# 补充 PATH
export PATH=$PATH:/usr/local/bin:/opt/homebrew/bin:/Applications/Docker.app/Contents/Resources/bin

# 检测执行环境
MYSQL_CONTAINER=""
if command -v docker >/dev/null 2>&1 && docker ps >/dev/null 2>&1; then
    MYSQL_CONTAINER=$(docker ps --filter "status=running" --format "{{`{{.Names}}`}}" | grep "mysql" | head -n1 || true)
fi

set +e
if [ -n "${MYSQL_CONTAINER}" ]; then
    echo "▶ 通过 Docker 容器 [${MYSQL_CONTAINER}] 执行..."
    if [ -n "${DB_PASS}" ]; then
        docker exec -i "${MYSQL_CONTAINER}" env MYSQL_PWD="${DB_PASS}" mysql -u"${DB_USER}" "${DB_NAME}" < "${SQL_FILE}"
    else
        docker exec -i "${MYSQL_CONTAINER}" mysql -u"${DB_USER}" "${DB_NAME}" < "${SQL_FILE}"
    fi
    RC=$?
else
    echo "▶ 通过本地 mysql 客户端执行 (${DB_USER}@${DB_HOST}:${DB_PORT}/${DB_NAME})..."
    if ! command -v mysql >/dev/null 2>&1; then
        echo "❌ 未找到 mysql 客户端，且未检测到运行中的 MySQL 容器。"
        echo "请安装: brew install mysql-client"
        exit 1
    fi
    if [ -n "${DB_PASS}" ]; then
        env MYSQL_PWD="${DB_PASS}" mysql -h "${DB_HOST}" -P "${DB_PORT}" -u "${DB_USER}" "${DB_NAME}" < "${SQL_FILE}"
    else
        mysql -h "${DB_HOST}" -P "${DB_PORT}" -u "${DB_USER}" "${DB_NAME}" < "${SQL_FILE}"
    fi
    RC=$?
fi
set -e

if [ ${RC} -eq 0 ]; then
    echo ""
    echo "═══════════════════════════════════════════"
    echo " ✅ 迁移成功: ${SQL_BASENAME}"
    echo "═══════════════════════════════════════════"
else
    echo ""
    echo "❌ 迁移失败 (返回码: ${RC})"
    exit ${RC}
fi
