// Package middleware 提供网关与 API 服务通用的 Gin 中间件。
//
// 包含：
//   - JWT(Manager): Bearer token 校验 + 公开路径白名单 + 过期返回 403
//   - InternalAuth: X-Internal-Secret 校验，保护 /internal/* 私域路由
//   - RequestID: 全链路请求 ID 生成/透传
//   - CORS: 白名单 origin + AllowCredentials（与 Spring Security 行为对齐）
//   - RateLimit: Redis 固定窗口限流，多副本安全，fail-open
//   - PrometheusMetrics: http_requests_total/duration/in_flight 指标
package middleware

import (
	"crypto/rand"
	"crypto/subtle"
	"fmt"
	"net/http"
	"strings"

	"github.com/gin-gonic/gin"

	"{{.GoModulePath}}/pkg-platform-core/response"
)

// ---------------- RequestID ----------------

const RequestIDHeader = "X-Request-ID"

// RequestID 生成或透传 X-Request-ID，写入 c.Set("requestID") 与响应头。
func RequestID() gin.HandlerFunc {
	return func(c *gin.Context) {
		id := c.GetHeader(RequestIDHeader)
		if id == "" {
			id = newUUIDv4()
		}
		c.Set("requestID", id)
		c.Header(RequestIDHeader, id)
		c.Next()
	}
}

func newUUIDv4() string {
	b := make([]byte, 16)
	_, _ = rand.Read(b)
	b[6] = (b[6] & 0x0f) | 0x40
	b[8] = (b[8] & 0x3f) | 0x80
	return fmt.Sprintf("%08x-%04x-%04x-%04x-%012x", b[0:4], b[4:6], b[6:8], b[8:10], b[10:16])
}

// ---------------- InternalAuth ----------------

// InternalAuth 校验 X-Internal-Secret 请求头，保护 /internal/* 私域。
// secret 为空时跳过验证（开发环境）。
func InternalAuth(secret string) gin.HandlerFunc {
	return func(c *gin.Context) {
		if secret == "" {
			c.Next()
			return
		}
		provided := c.GetHeader("X-Internal-Secret")
		if subtle.ConstantTimeCompare([]byte(provided), []byte(secret)) != 1 {
			c.AbortWithStatusJSON(http.StatusForbidden, gin.H{
				"code": "000403", "msg": "forbidden: invalid internal secret",
			})
			return
		}
		c.Next()
	}
}

// ---------------- CORS ----------------

// CORS 白名单 origin + AllowCredentials。allowedHeaders 可追加业务自定义头。
func CORS(allowedOrigins []string, extraHeaders ...string) gin.HandlerFunc {
	originSet := make(map[string]bool, len(allowedOrigins))
	for _, o := range allowedOrigins {
		originSet[o] = true
	}
	defaultHeaders := "Origin, Content-Type, Authorization, X-Requested-With, X-Refresh-Token, X-Device-ID, X-Request-ID"
	if len(extraHeaders) > 0 {
		defaultHeaders = defaultHeaders + ", " + strings.Join(extraHeaders, ", ")
	}

	return func(c *gin.Context) {
		origin := c.Request.Header.Get("Origin")
		if originSet[origin] {
			c.Header("Access-Control-Allow-Origin", origin)
			c.Header("Access-Control-Allow-Credentials", "true")
		}
		c.Header("Access-Control-Allow-Methods", "GET, POST, PUT, DELETE, OPTIONS")
		c.Header("Access-Control-Allow-Headers", defaultHeaders)
		c.Header("Access-Control-Expose-Headers", "Content-Length, Content-Type, X-Request-ID, Set-Cookie")
		c.Header("Access-Control-Max-Age", "86400")

		if c.Request.Method == http.MethodOptions {
			c.AbortWithStatus(http.StatusNoContent)
			return
		}
		c.Next()
	}
}

// ---------------- JWT ----------------

// JWTValidator 业务方需提供：从 token 字符串解析 claims 的能力。
type JWTValidator interface {
	ValidateToken(token string) (Claims, error)
}

// Claims JWT 必需的载荷。业务可自由扩展。
type Claims struct {
	UserUUID    string
	MemberLevel string
	Expired     bool // ValidateToken 内部已识别过期，给上层用于 403 判断
}

// JWTOptions 配置公开路径前缀与可选的 RefreshTokenCookieName。
type JWTOptions struct {
	// PublicPathPrefixes 命中其中任一前缀即视为匿名可访问，但仍尝试解析 token 注入身份头。
	PublicPathPrefixes []string
	// RefreshTokenCookieName 例如 "refreshToken_"。当请求里存在该 cookie 但 access token 缺失/过期时返回 403（触发前端自动 refresh）。
	RefreshTokenCookieName string
}

// JWT 验证 Bearer token，注入 X-User-UUID / X-Member-Level 给下游。
func JWT(validator JWTValidator, opts JWTOptions) gin.HandlerFunc {
	return func(c *gin.Context) {
		path := c.Request.URL.Path
		token := extractToken(c)

		if matchAnyPrefix(path, opts.PublicPathPrefixes) {
			if token != "" {
				if claims, err := validator.ValidateToken(token); err == nil {
					injectIdentity(c, claims)
				}
			}
			c.Next()
			return
		}

		if token == "" {
			if opts.RefreshTokenCookieName != "" && hasCookiePrefix(c, opts.RefreshTokenCookieName) {
				response.Forbidden(c, "100002", "Access token expired, please refresh")
			} else {
				response.Unauthorized(c, "100001", "Missing or invalid authorization header")
			}
			c.Abort()
			return
		}

		claims, err := validator.ValidateToken(token)
		if err != nil {
			if claims.Expired {
				response.Forbidden(c, "100002", "Access token expired, please refresh")
			} else {
				response.Unauthorized(c, "100001", "Invalid access token")
			}
			c.Abort()
			return
		}
		injectIdentity(c, claims)
		c.Next()
	}
}

func extractToken(c *gin.Context) string {
	if h := c.GetHeader("Authorization"); strings.HasPrefix(h, "Bearer ") {
		return strings.TrimPrefix(h, "Bearer ")
	}
	if t := c.Query("t"); t != "" {
		return t
	}
	return ""
}

func injectIdentity(c *gin.Context, claims Claims) {
	if claims.UserUUID != "" {
		c.Set("userUUID", claims.UserUUID)
		c.Request.Header.Set("X-User-UUID", claims.UserUUID)
	}
	if claims.MemberLevel != "" {
		c.Request.Header.Set("X-Member-Level", claims.MemberLevel)
	}
}

func matchAnyPrefix(path string, prefixes []string) bool {
	for _, p := range prefixes {
		if strings.HasPrefix(path, p) {
			return true
		}
	}
	return false
}

func hasCookiePrefix(c *gin.Context, prefix string) bool {
	for _, ck := range c.Request.Cookies() {
		if strings.HasPrefix(ck.Name, prefix) {
			return true
		}
	}
	return false
}
